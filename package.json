{
  "name": "cineia_gui",
  "version": "1.0.1",
  "description": "",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:cli:mac": "./scripts/build-cli-mac.sh",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "build": {
    "appId": "com.cineia.gui",
    "mac": {
      "target": "dmg",
      "category": "public.app-category.video",
      "extraResources": [
        {
          "from": "bin/mac",
          "to": "bin",
          "filter": [
            "**/*"
          ]
        }
      ]
    },
    "win": {
      "target": "nsis",
      "extraResources": [
        {
          "from": "bin/win",
          "to": "bin",
          "filter": [
            "**/*"
          ]
        }
      ]
    },
    "directories": {
      "output": "dist"
    }
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "electron": "^40.0.0",
    "electron-builder": "^26.4.0"
  }
}
